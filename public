<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grow A Garden 2 - Realtime Monitor</title>
    <style>
        body {
            background-color: #0d1117;
            color: #c9d1d9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        h1 {
            color: #58a6ff;
            border-bottom: 1px solid #21262d;
            padding-bottom: 10px;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .card {
            background-color: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 15px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #30363d;
            padding-bottom: 8px;
            margin-bottom: 10px;
        }
        .username {
            font-weight: bold;
            color: #f0883e;
            font-size: 1.1em;
        }
        .status-online {
            width: 10px;
            height: 10px;
            background-color: #2ea44f;
            border-radius: 50%;
        }
        .sheckles {
            font-size: 1.2em;
            color: #ffd700;
            font-weight: bold;
            margin: 10px 0;
        }
        .inventory-list {
            font-size: 0.9em;
            background: #0d1117;
            padding: 8px;
            border-radius: 5px;
        }
        .time {
            font-size: 0.8em;
            color: #8b949e;
            margin-top: 10px;
            text-align: right;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🌱 Grow A Garden 2 - Live Monitor</h1>
        <div id="loading">Menghubungkan ke API...</div>
        <div class="grid" id="accounts-grid"></div>
    </div>

    <script>
        async function fetchAccounts() {
            try {
                const response = await fetch('/api/accounts');
                const accounts = await response.json();
                
                const grid = document.getElementById('accounts-grid');
                const loading = document.getElementById('loading');
                grid.innerHTML = '';
                
                const usernames = Object.keys(accounts);
                if (usernames.length === 0) {
                    loading.innerText = "Belum ada akun yang online. Jalankan script Delta di Roblox Anda!";
                    return;
                }
                
                loading.style.display = 'none';

                usernames.forEach(username => {
                    const acc = accounts[username];
                    const card = document.createElement('div');
                    card.className = 'card';
                    
                    // Format tampilan inventory
                    let invHtml = '';
                    for (const [item, qty] of Object.entries(acc.inventory)) {
                        invHtml += `<div>• ${item.replace(/_/g, ' ')}: <strong>${qty}</strong></div>`;
                    }

                    card.innerHTML = `
                        <div class="card-header">
                            <span class="username">${username}</span>
                            <div class="status-online"></div>
                        </div>
                        <div class="sheckles">💰 ${Number(acc.sheckles).toLocaleString('id-ID')} Sheckles</div>
                        <div class="inventory-list">
                            <strong>Inventory:</strong>
                            ${invHtml || '<div>Kosong</div>'}
                        </div>
                        <div class="time">Update terakhir: ${acc.lastUpdated}</div>
                    `;
                    grid.appendChild(card);
                });
            } catch (err) {
                console.error("Gagal mengambil data:", err);
            }
        }

        // Ambil data pertama kali & set up interval penarikan data otomatis setiap 3 detik
        fetchAccounts();
        setInterval(fetchAccounts, 3000);
    </script>
</body>
</html>
